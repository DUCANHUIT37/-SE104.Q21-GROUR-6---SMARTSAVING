spring.application.name=demo

# ==========================================
# CẤU HÌNH KẾT NỐI DATABASE (CHỌN 1 TRONG 2)
# ==========================================

# --- OPTION 1: SUPABASE (POSTGRESQL - KHUYÊN DÙNG ĐỂ CHẠY ONLINE) ---
# QUAN TRỌNG: Dùng port 6543 (Transaction Pooler) KHÔNG PHẢI 5432 (Session mode)
# Port 5432 giới hạn 14 connections -> gây lỗi "max clients reached" trên Render
# Thêm &prepareThreshold=0 vì Transaction Pooler không hỗ trợ server-side prepared statements
spring.datasource.url=${SPRING_DATASOURCE_URL:jdbc:postgresql://aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?sslmode=require&prepareThreshold=0}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME:postgres.[YOUR_PROJECT_ID]}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD:[YOUR_PASSWORD]}
spring.datasource.driver-class-name=org.postgresql.Driver

# --- OPTION 2: LOCAL MYSQL (XAMPP) ---
# spring.datasource.url=jdbc:mysql://localhost:3306/smart_savings?useUnicode=true&characterEncoding=UTF-8&serverTimezone=Asia/Ho_Chi_Minh
# spring.datasource.username=root
# spring.datasource.password=
# spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ==========================================
# HIKARICP – GIỚI HẠN CONNECTION POOL
# Supabase Transaction Pooler hỗ trợ nhiều connections hơn nhưng free tier
# Render nên giữ pool nhỏ (3-5) để tránh lỗi
# ==========================================
spring.datasource.hikari.maximum-pool-size=3
spring.datasource.hikari.minimum-idle=1
spring.datasource.hikari.connection-timeout=30000
spring.datasource.hikari.idle-timeout=600000
spring.datasource.hikari.max-lifetime=1800000
spring.datasource.hikari.data-source-properties.prepareThreshold=0

# ===============================
# CẤU HÌNH JPA / HIBERNATE CHUNG
# ===============================
spring.jpa.show-sql=false
spring.jpa.hibernate.ddl-auto=update
# Tắt open-in-view để không giữ connection suốt HTTP request lifecycle
spring.jpa.open-in-view=false
# KHÔNG khai báo hibernate.dialect thủ công -> Hibernate tự detect, tránh warning HHH90000025

# ===============================
# SERVER
# ===============================
server.port=${PORT:8080}